# Include documentation
include README.md
include LICENSE
include CHANGELOG.md

# Include requirements
include src/computing/requirements.txt

# Include data files
recursive-include src/computing *.json
recursive-include src/computing *.yaml
recursive-include src/computing *.md

# Include test data (if any)
recursive-include tests *.py

# Exclude compiled files
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
