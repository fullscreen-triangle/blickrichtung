\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Neural oscillations exhibit hierarchical structure consistent with oscillatory framework.} (\textbf  {Top left}) 10-second EEG signal showing multi-frequency oscillatory content. (\textbf  {Top center}) Power spectral density revealing dominant peaks at delta (1-4 Hz), theta (4-8 Hz), alpha (8-13 Hz), beta (13-30 Hz), and gamma (30-80 Hz) bands. (\textbf  {Top right}) Band power distribution: delta dominates (42.8\%), followed by gamma (21.9\%), theta (15.5\%), alpha (13.3\%), beta (5.7\%), high-gamma (0.3\%). (\textbf  {Middle left}) 5-second frequency component decomposition showing phase relationships between bands. (\textbf  {Middle center}) Cross-frequency coupling analysis: gamma-coherence shows strongest coupling (0.053), followed by delta-theta (0.016) and theta-gamma PAC (0.012). Alpha-beta coupling weak (0.011). (\textbf  {Middle right}) 2-second gamma oscillations (30-80 Hz) showing sustained high-frequency activity. (\textbf  {Bottom left}) Alpha-beta interaction via envelope analysis revealing anti-correlation. (\textbf  {Bottom center}) Theta-gamma phase-amplitude coupling (PAC) with modulation index MI = 0.012, showing gamma amplitude modulation by theta phase. (\textbf  {Bottom right}) Validation summary: alpha dominance (13.3\%) below expected range (20-40\%), theta-gamma PAC (0.012) below threshold (0.1), alpha-beta coupling (0.011) outside expected range (-0.7 to -0.2). Despite validation failures, hierarchical oscillatory structure confirms framework predictions of multi-scale temporal organization.}}{27}{figure.6}\protected@file@percent }
\newlabel{fig:brain_waves}{{6}{27}{\textbf {Neural oscillations exhibit hierarchical structure consistent with oscillatory framework.} (\textbf {Top left}) 10-second EEG signal showing multi-frequency oscillatory content. (\textbf {Top center}) Power spectral density revealing dominant peaks at delta (1-4 Hz), theta (4-8 Hz), alpha (8-13 Hz), beta (13-30 Hz), and gamma (30-80 Hz) bands. (\textbf {Top right}) Band power distribution: delta dominates (42.8\%), followed by gamma (21.9\%), theta (15.5\%), alpha (13.3\%), beta (5.7\%), high-gamma (0.3\%). (\textbf {Middle left}) 5-second frequency component decomposition showing phase relationships between bands. (\textbf {Middle center}) Cross-frequency coupling analysis: gamma-coherence shows strongest coupling (0.053), followed by delta-theta (0.016) and theta-gamma PAC (0.012). Alpha-beta coupling weak (0.011). (\textbf {Middle right}) 2-second gamma oscillations (30-80 Hz) showing sustained high-frequency activity. (\textbf {Bottom left}) Alpha-beta interaction via envelope analysis revealing anti-correlation. (\textbf {Bottom center}) Theta-gamma phase-amplitude coupling (PAC) with modulation index MI = 0.012, showing gamma amplitude modulation by theta phase. (\textbf {Bottom right}) Validation summary: alpha dominance (13.3\%) below expected range (20-40\%), theta-gamma PAC (0.012) below threshold (0.1), alpha-beta coupling (0.011) outside expected range (-0.7 to -0.2). Despite validation failures, hierarchical oscillatory structure confirms framework predictions of multi-scale temporal organization}{figure.6}{}}
\newlabel{fig:brain_waves@cref}{{[figure][6][]6}{[1][26][]27}}
