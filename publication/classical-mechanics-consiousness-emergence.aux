\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Cognitive states emerge from coupled oscillatory dynamics across hierarchical levels.} (\textbf  {Top left}) Cognitive state dynamics over 175 seconds showing periodic fluctuations in attention (green, peak level 7), working memory (blue, level 3), executive function (red, level 1), and consciousness (purple, level 3). (\textbf  {Top center}) Neural oscillations (10 seconds) displaying multi-scale activity: working memory (blue, 0-50 offset), attention (green, 50-100 offset), executive (red, 100-150 offset), consciousness (purple, 150-200 offset). (\textbf  {Top right}) Cognitive performance showing reaction time (red, 360-420 ms) anti-correlated with accuracy (blue, 0.6-1.3) over 175 seconds. (\textbf  {Middle left}) Cognitive network coupling matrix revealing weak coupling: attention-working memory (0.2), working memory-executive (0.6), executive-consciousness (0.4), with strong self-coupling (1.0 diagonal). (\textbf  {Middle center}) Key coupling relationships: attention-executive (0.0037), working memory-consciousness (0.0039), consciousness-coherence (0.0030). (\textbf  {Middle right}) RT-neural correlation (r = 0.329) showing positive relationship between reaction time and attention neural activity. (\textbf  {Bottom left}) Processing efficiency oscillating between 0.3-0.8 with $\\sim$40-second period. (\textbf  {Bottom center}) Cognitive resource levels (attention, working memory, executive, consciousness) showing periodic depletion-recovery cycles. (\textbf  {Bottom right}) Validation summary: attention-executive coupling (0.004) below required threshold (0.4), WM-consciousness coupling (0.004) below threshold (0.35), RT-neural correlation (0.329) outside expected range (-0.8 to -0.2), cognitive coherence (0.003) below threshold (0.3). Despite quantitative mismatches, qualitative patterns confirm oscillatory coupling between cognitive and neural levels.}}{21}{figure.5}\protected@file@percent }
\newlabel{fig:cognitive_processing}{{5}{21}{\textbf {Cognitive states emerge from coupled oscillatory dynamics across hierarchical levels.} (\textbf {Top left}) Cognitive state dynamics over 175 seconds showing periodic fluctuations in attention (green, peak level 7), working memory (blue, level 3), executive function (red, level 1), and consciousness (purple, level 3). (\textbf {Top center}) Neural oscillations (10 seconds) displaying multi-scale activity: working memory (blue, 0-50 offset), attention (green, 50-100 offset), executive (red, 100-150 offset), consciousness (purple, 150-200 offset). (\textbf {Top right}) Cognitive performance showing reaction time (red, 360-420 ms) anti-correlated with accuracy (blue, 0.6-1.3) over 175 seconds. (\textbf {Middle left}) Cognitive network coupling matrix revealing weak coupling: attention-working memory (0.2), working memory-executive (0.6), executive-consciousness (0.4), with strong self-coupling (1.0 diagonal). (\textbf {Middle center}) Key coupling relationships: attention-executive (0.0037), working memory-consciousness (0.0039), consciousness-coherence (0.0030). (\textbf {Middle right}) RT-neural correlation (r = 0.329) showing positive relationship between reaction time and attention neural activity. (\textbf {Bottom left}) Processing efficiency oscillating between 0.3-0.8 with $\\sim$40-second period. (\textbf {Bottom center}) Cognitive resource levels (attention, working memory, executive, consciousness) showing periodic depletion-recovery cycles. (\textbf {Bottom right}) Validation summary: attention-executive coupling (0.004) below required threshold (0.4), WM-consciousness coupling (0.004) below threshold (0.35), RT-neural correlation (0.329) outside expected range (-0.8 to -0.2), cognitive coherence (0.003) below threshold (0.3). Despite quantitative mismatches, qualitative patterns confirm oscillatory coupling between cognitive and neural levels}{figure.5}{}}
\newlabel{fig:cognitive_processing@cref}{{[figure][5][]5}{[1][20][]21}}
